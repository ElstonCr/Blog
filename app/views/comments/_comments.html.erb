<div>
    <h3>Comments</h3>

    <div>
        <% comments.each do |comment| %>
        <div>
            <h6> Commented By: </h6>
            <%= comment.commenter %>

            <h6>Comment</h6>
            <%= comment.body %>

            <%= link_to "Delete", [comment.article, comment],
                data: {
                    turbo_method: :delete,
                    turbo_confirm: "Do you want to delete this comment?"
                } %>
        </div>
        <% end %>
    </div>

    <div>
        <%= render partial: "comments/form", locals: { article: article, comments: comments } %>
    </div>
</div>
