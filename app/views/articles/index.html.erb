<div>
    <h1>Articles</h1>

    <p><%= "We have #{Article.public_count} articles published and counting...!" %> </p>

    <ul>
        <% @articles.each do |article| %>
            <li>
                <%= link_to article.title, article %>
            </li>
        <% end %>
    </ul>
</div>

<div>
    <%= link_to "Add new Article", new_article_path %>
</div>
