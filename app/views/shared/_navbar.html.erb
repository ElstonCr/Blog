<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <%= link_to "BLOG", root_path, class: "navbar-brand" %>
    
    <div class="d-flex">
      <% if user_signed_in? %>
        <div class="dropdown">
            <button class="btn btn-secondary rounded-circle p-2" type="button" data-bs-toggle="dropdown" style="width: 45px; height: 45px;">
                <i class="bi bi-person fs-5"></i>
            </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><h6 class="dropdown-header"><%= current_user.email %></h6></li>
            <li><span class="dropdown-item-text text-muted small"><%= current_user.role.upcase %></span></li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "dropdown-item" %>
            </li>
          </ul>
        </div>
      <% else %>
        <%= link_to "Login", new_user_session_path, class: "btn btn-outline-light" %>
      <% end %>
    </div>
  </div>
</nav>
